
# Supabase Dashboard > Project Settings > API
#  - Project URL
#  - "Publishable key" (sb_publishable_...)  ← use esta no frontend


VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Notificações push (Web Push) — chave PÚBLICA VAPID (pode ficar no frontend).
# Gere o par com:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
