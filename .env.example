# Copie para ".env" (local) e configure também no painel da Vercel (produção).
# Supabase Dashboard > Project Settings > API
#  - Project URL
#  - "Publishable key" (sb_publishable_...)  ← use esta no frontend
# NUNCA use a "secret key" (sb_secret_...) no frontend.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# (compatível com a chave antiga, caso ainda use a anon legacy)
# VITE_SUPABASE_ANON_KEY=sua-anon-key-legacy
